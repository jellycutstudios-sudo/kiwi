rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────
    // Helper functions
    // ─────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    // Role checks using Custom Claims to save on read costs and avoid loop/recursion issues
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(uid()));
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        ('role' in request.auth.token && request.auth.token.role == 'super_admin') ||
        (exists(/databases/$(database)/documents/users/$(uid())) && getUserDoc().data.role == 'super_admin')
      );
    }

    function isUserAdmin(restaurantId) {
      return isSignedIn() && (
        isSuperAdmin() || 
        ('role' in request.auth.token && request.auth.token.role == 'admin' && 'restaurantId' in request.auth.token && request.auth.token.restaurantId == restaurantId) ||
        (exists(/databases/$(database)/documents/users/$(uid())) && getUserDoc().data.role == 'admin' && getUserDoc().data.restaurantId == restaurantId)
      );
    }
    
    // Fallback or explicit check for staff access to specific restaurant
    function belongsToRestaurant(restaurantId) {
       return isSignedIn() && (
         isSuperAdmin() || 
         ('restaurantId' in request.auth.token && request.auth.token.restaurantId == restaurantId) ||
         (exists(/databases/$(database)/documents/users/$(uid())) && getUserDoc().data.restaurantId == restaurantId)
       );
    }
    
    // Staff member check: support both custom token claims (Blaze plan)
    // and legacy anonymous sessions (Spark free plan fallback)
    function isStaffMember(restaurantId) {
       return isSignedIn() && (
         isSuperAdmin() || 
         ('restaurantId' in request.auth.token && request.auth.token.restaurantId == restaurantId) ||
         ('firebase' in request.auth.token && 'sign_in_provider' in request.auth.token.firebase && request.auth.token.firebase.sign_in_provider == 'anonymous') ||
         (exists(/databases/$(database)/documents/users/$(uid())) && getUserDoc().data.restaurantId == restaurantId)
       );
    }


    // ─────────────────────────────────────────────
    // /users — admins can only read/write their own doc
    // ─────────────────────────────────────────────
    match /users/{userId} {
      allow read:  if isSignedIn() && uid() == userId;
      // Protect user role creation and changes
      allow create: if isSignedIn() && uid() == userId && request.resource.data.role == 'admin';
      allow update: if isSignedIn() && uid() == userId && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'restaurantId'])
      ) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ─────────────────────────────────────────────
    // /restaurants
    // ─────────────────────────────────────────────
    match /restaurants/{restaurantId} {
      // Public read — online order page needs restaurant name/logo
      // but we shouldn't expose sensitive config like API keys.
      // A better architecture is to separate public profile from config.
      // For now, we restrict to authenticated users or public (needs careful field filtering in UI)
      allow read: if true;
      // Create — any signed-in user can register a new restaurant
      allow create: if isSignedIn();
      // Update/Delete — only authenticated admin-level users who belong to this restaurant
      allow update, delete: if isUserAdmin(restaurantId);

      // Staff — admin write only. Read restricted to admins or via backend.
      // Client shouldn't fetch all PINs.
      // Staff: list and write restricted to admins.
      // Individual staff docs can be fetched by authenticated members.
      match /staff/{staffId} {
        allow get:   if isStaffMember(restaurantId);
        allow list:  if isUserAdmin(restaurantId);
        allow write: if isUserAdmin(restaurantId);
      }

      // Secure client-side lookup collection:
      // Permits get (reading individual docs if you know the exact PIN),
      // but strictly denies listing/querying the entire collection.
      match /pins/{pin} {
        allow get:   if isSignedIn();
        allow list:  if false;
        allow write: if isUserAdmin(restaurantId);
      }

      // Menu — public read, admin write only
      match /menu/{catId} {
        allow read:  if true;
        allow write: if isUserAdmin(restaurantId);
      }

      // Tables — public read, authenticated staff write
      match /tables/{tableId} {
        allow read:  if true;
        allow write: if isStaffMember(restaurantId);
      }

      // Orders — public create (online orders), authenticated staff read/update/delete
      match /orders/{orderId} {
        allow read:   if isStaffMember(restaurantId);
        allow create: if true;                     // customers place online orders without auth
        allow update, delete: if isStaffMember(restaurantId);
      }

      // Tokens — public read (TV display), authenticated staff write
      match /tokens/{date} {
        allow read:  if true;
        allow write: if isStaffMember(restaurantId);
      }

      // Delivery Sync logs — read-only for authenticated, write via Cloud Functions only
      match /deliverySync/{platform}/logs/{logId} {
        allow read:  if isStaffMember(restaurantId);
        allow write: if false;
      }

      // Delivery Settings — authenticated admin read/write
      match /deliverySettings/{platform} {
        allow read, write: if isUserAdmin(restaurantId);
        match /{document=**} {
          allow read, write: if isUserAdmin(restaurantId);
        }
      }

      // Inventory — authenticated staff read/write
      match /inventory/{itemId} {
        allow read:  if isStaffMember(restaurantId);
        allow write: if isStaffMember(restaurantId);
      }

      // Payroll — SENSITIVE: admin-only
      match /payroll/{month}/entries/{staffEntryId} {
        allow read, write: if isUserAdmin(restaurantId);
      }

      // Customers CRM — authenticated staff read/write
      match /customers/{customerId} {
        allow read, write: if isStaffMember(restaurantId);
      }

      // Reservations — authenticated staff read/write
      match /reservations/{reservationId} {
        allow read, write: if isStaffMember(restaurantId);
      }

      // Waitlist Queue — authenticated staff read/write
      match /waitlist/{waitlistId} {
        allow read, write: if isStaffMember(restaurantId);
      }

      // Suppliers Directory — admin only (financial data)
      match /suppliers/{supplierId} {
        allow read, write: if isUserAdmin(restaurantId);
      }

      // Purchase Orders — admin only
      match /purchase_orders/{poId} {
        allow read, write: if isUserAdmin(restaurantId);
      }

      // Gift Cards & Vouchers — authenticated staff read, cashier/admin write
      match /gift_cards/{cardId} {
        allow read:  if isStaffMember(restaurantId);
        allow write: if isStaffMember(restaurantId);   // cashier can redeem (balance update)
      }

      // Shifts & Drawer Tills — authenticated staff read/write
      match /shifts/{shiftId} {
        allow read, write: if isStaffMember(restaurantId);
      }

      // Void Audits Ledger — SENSITIVE: read admin-only, write via staff only
      match /void_logs/{logId} {
        allow read:  if isUserAdmin(restaurantId);
        allow write: if isStaffMember(restaurantId);
      }
    }
  }
}
