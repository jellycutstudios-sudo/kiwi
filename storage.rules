rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─────────────────────────────────────────────────────────
    // Menu item images — authenticated restaurant admins only
    // Stored at: menuImages/{restaurantId}/{filename}
    // ─────────────────────────────────────────────────────────
    match /menuImages/{restaurantId}/{filename} {
      // Public read — images are embedded in the customer-facing online order page
      allow read: if true;

      // Write restricted to admins of that specific restaurant
      allow write: if request.auth != null
        && (
          request.auth.token.role == 'super_admin'
          || (
            (request.auth.token.role == 'admin')
            && request.auth.token.restaurantId == restaurantId
          )
        )
        // Enforce image content type
        && request.resource.contentType.matches('image/.*')
        // Enforce max file size: 2 MB
        && request.resource.size <= 2 * 1024 * 1024;
    }

    // ─────────────────────────────────────────────────────────
    // Deny all other paths by default
    // ─────────────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
