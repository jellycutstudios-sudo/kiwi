# ── Firebase ────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=YOUR_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID

# ── Demo Mode ────────────────────────────────────────────────
# Set to 'true' ONLY on demo/staging deployments.
# When false (default), all demo credentials and the demo modal are hidden.
# NEVER set to 'true' in production.
VITE_ENABLE_DEMO=false

# ── Webhook Security ─────────────────────────────────────────
# Secret token for incoming delivery platform webhooks (Zomato, Swiggy, etc.)
# Set the same value in your Cloud Functions environment:
# firebase functions:config:set webhook.secret="YOUR_SECRET"
WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET
